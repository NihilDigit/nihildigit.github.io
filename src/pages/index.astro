---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Socials from "@/components/Socials.astro";
import LinkButton from "@/components/LinkButton.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import IconRss from "@/assets/icons/IconRss.svg";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import { SOCIALS } from "@/constants";

const posts = await getCollection("blog");
const sortedPosts = getSortedPosts(posts);

const REPOS = ["NihilDigit/waybar-ai-usage", "NihilDigit/renpak"];
const projects = await Promise.all(
  REPOS.map(async repo => {
    try {
      const res = await fetch(`https://api.github.com/repos/${repo}`);
      if (!res.ok) throw new Error(`GitHub API ${res.status}`);
      const data = await res.json();
      return {
        name: data.name,
        description: data.description || "",
        url: data.html_url,
        language: data.language || "",
        stars: data.stargazers_count,
      };
    } catch {
      // Fallback if API fails
      const name = repo.split("/")[1];
      return { name, description: "", url: `https://github.com/${repo}`, language: "", stars: 0 };
    }
  })
);
---

<Layout>
  <Header />
  <main id="main-content" data-layout="index" class="app-layout">
    <section id="hero" class="pt-8 pb-6 border-b border-border">
      <h1 class="my-4 inline-block text-4xl font-bold sm:my-8 sm:text-5xl">
        Digital Odyssey
      </h1>
      <a
        target="_blank"
        href="/rss.xml"
        class="inline-block"
        aria-label="rss feed"
        title="RSS Feed"
      >
        <IconRss
          width={20}
          height={20}
          class="scale-125 stroke-accent stroke-3 rtl:-rotate-90"
        />
      </a>
      <p class="text-foreground/80">
        EdgeAI / CV / Linux Ricing / MultiMedia / Vibe Coding / GenAI
      </p>
      {
        SOCIALS.length > 0 && (
          <div class="mt-3 flex max-sm:flex-col sm:items-center">
            <Socials />
          </div>
        )
      }
    </section>

    <!-- Study Notes -->
    <section id="notes" class="pt-10 pb-6 border-b border-border">
      <h2 class="text-2xl font-semibold tracking-wide mb-4">Study Notes</h2>
      <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
        <a
          href="https://nihildigit.dev/sedgewick/docs/"
          target="_blank"
          rel="noopener"
          class="group block rounded-xl border border-border p-5 transition-all hover:border-accent/50 hover:shadow-md"
        >
          <div class="flex items-center justify-between">
            <h3 class="text-lg font-semibold group-hover:text-accent">Sedgewick Algorithms</h3>
            <span class="rounded-full bg-green-100 px-2.5 py-0.5 text-xs font-medium text-green-800 dark:bg-green-900/30 dark:text-green-400">Live</span>
          </div>
          <p class="mt-2 text-sm text-foreground/60">算法学习笔记</p>
        </a>
        <div
          class="block rounded-xl border border-border/50 p-5 opacity-60"
        >
          <div class="flex items-center justify-between">
            <h3 class="text-lg font-semibold">CSAPP</h3>
            <span class="rounded-full bg-amber-100 px-2.5 py-0.5 text-xs font-medium text-amber-800 dark:bg-amber-900/30 dark:text-amber-400">WIP</span>
          </div>
          <p class="mt-2 text-sm text-foreground/60">深入理解计算机系统</p>
        </div>
      </div>
    </section>

    <!-- Projects -->
    <section id="projects" class="pt-10 pb-6 border-b border-border">
      <h2 class="text-2xl font-semibold tracking-wide mb-4">Projects</h2>
      <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
        {projects.map(p => (
          <a
            href={p.url}
            target="_blank"
            rel="noopener"
            class="group block rounded-xl border border-border p-5 transition-all hover:border-accent/50 hover:shadow-md"
          >
            <h3 class="text-lg font-semibold group-hover:text-accent">{p.name}</h3>
            <p class="mt-2 text-sm text-foreground/60">{p.description}</p>
            <div class="mt-3 flex gap-3 text-xs text-foreground/50">
              {p.language && <span>{p.language}</span>}
              <span>&#9733; {p.stars}</span>
            </div>
          </a>
        ))}
      </div>
    </section>

    <!-- Recent Posts (compact) -->
    <section id="recent-posts" class="pt-10 pb-6">
      <h2 class="text-2xl font-semibold tracking-wide mb-4">Recent Posts</h2>
      <ul class="space-y-2">
        {sortedPosts.slice(0, 5).map(({ data, id }) => (
          <li>
            <a href={`/posts/${id}/`} class="flex items-baseline justify-between gap-4 py-1.5 group">
              <span class="text-foreground/90 group-hover:text-accent transition-colors truncate">{data.title}</span>
              <span class="shrink-0 text-sm text-foreground/40">{data.pubDatetime.toISOString().slice(0, 10)}</span>
            </a>
          </li>
        ))}
      </ul>
      <div class="mt-6 text-center">
        <LinkButton href="/posts/">
          All Posts
          <IconArrowRight class="inline-block rtl:-rotate-180" />
        </LinkButton>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset?.layout;
    if (indexLayout) {
      sessionStorage.setItem("backUrl", "/");
    }
  });
</script>
